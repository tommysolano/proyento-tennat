{
  "name": "multi-tenant-mern-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Cascaron inicial MERN para plataforma SaaS multi-tenant con roles jerarquicos.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "seed": "npm run seed --workspace server",
    "seed:superadmin": "npm run seed:superadmin --workspace server",
    "install:all": "npm install",
    "start:server": "npm start --workspace server",
    "test": "npm test --workspace server",
    "build": "npm run build --workspace client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
