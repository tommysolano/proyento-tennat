# Server
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db
JWT_SECRET=change_me_secure_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:5173
SUPERADMIN_NAME=Programador
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123456
CREDENTIALS_ENCRYPTION_KEY=
REQUIRE_WEBHOOK_SIGNATURE=false
JOB_WORKER_ENABLED=true
JOB_WORKER_CONCURRENCY=2
JOB_MAX_ATTEMPTS=5
REALTIME_ENABLED=true
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com
WHATSAPP_SANDBOX_MODE=false
WHATSAPP_QR_ENABLED=false
WHATSAPP_QR_AUTO_RESTORE=true
WHATSAPP_QR_MAX_SESSIONS_PER_COMPANY=5
WHATSAPP_QR_MAX_ACTIVE_SESSIONS=20
WHATSAPP_QR_RESTORE_LIMIT=10
WHATSAPP_QR_QR_TTL_SECONDS=60
WHATSAPP_QR_SESSION_LEASE_SECONDS=90
WHATSAPP_QR_MAX_RECONNECT_ATTEMPTS=5
WHATSAPP_QR_RECONNECT_BASE_MS=2000
WHATSAPP_QR_RECONNECT_MAX_MS=60000
WHATSAPP_QR_ALLOW_GROUPS=false
MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_DIR=server/uploads
MEDIA_MAX_SIZE_MB=25
MEDIA_SIGNED_URL_TTL_SECONDS=300
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,audio/mpeg,audio/ogg,video/mp4,application/pdf
ALERTS_ENABLED=true

# Solo para el script manual de rotacion; no conservar juntas en produccion.
OLD_CREDENTIALS_ENCRYPTION_KEY=
NEW_CREDENTIALS_ENCRYPTION_KEY=

# Client
VITE_API_URL=http://localhost:4000/api
VITE_APP_NAME=TenantDesk
VITE_PUBLIC_BASE_URL=http://localhost:5173
