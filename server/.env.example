NODE_ENV=development
PORT=4000
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:5173
SUPERADMIN_NAME=Programador
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123456
# Clave AES-256 (32 bytes en hex[64] o base64) para cifrar tokens de Meta y el
# authState de WhatsApp QR en Mongo. OBLIGATORIA en produccion. Genera una con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=
REQUIRE_WEBHOOK_SIGNATURE=false
# Si es false, NO se procesan webhooks, envios ni workflows (todo queda encolado).
JOB_WORKER_ENABLED=true
JOB_WORKER_CONCURRENCY=2
JOB_MAX_ATTEMPTS=5
REALTIME_ENABLED=true
# Version vigente de Graph API. v20.0 quedo fuera de soporte a mediados de 2026.
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com

# ─────────── WhatsApp QR (Baileys) ───────────
# Interruptor maestro: sin esto en 'true', las sesiones QR estan DESACTIVADAS
# (assertEnabled() responde 503). Requiere CREDENTIALS_ENCRYPTION_KEY definida.
WHATSAPP_QR_ENABLED=false
# Reconecta al arrancar las sesiones con authState guardado. 'false' para no hacerlo.
WHATSAPP_QR_AUTO_RESTORE=true
WHATSAPP_QR_RESTORE_LIMIT=10
# Ingiere como salientes los mensajes enviados desde el telefono vinculado.
WHATSAPP_QR_INGEST_FROM_ME=true
# Procesar mensajes de grupos (@g.us). Por defecto se ignoran.
WHATSAPP_QR_ALLOW_GROUPS=false
# Limites y tuning (valores por defecto seguros; ajustar solo si hace falta).
WHATSAPP_QR_MAX_SESSIONS_PER_COMPANY=5
WHATSAPP_QR_MAX_ACTIVE_SESSIONS=20
WHATSAPP_QR_SESSION_LEASE_SECONDS=90
WHATSAPP_QR_QR_TTL_SECONDS=60
WHATSAPP_QR_SYNC_STUCK_MINUTES=3
WHATSAPP_QR_SYNC_STUCK_RETRIES=3
WHATSAPP_QR_HEALTH_INTERVAL_SECONDS=60
WHATSAPP_QR_MAX_RECONNECT_ATTEMPTS=5
WHATSAPP_QR_RECONNECT_BASE_MS=2000
WHATSAPP_QR_RECONNECT_MAX_MS=60000
MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_DIR=uploads
MEDIA_MAX_SIZE_MB=25
MEDIA_SIGNED_URL_TTL_SECONDS=300
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,audio/mpeg,audio/ogg,video/mp4,application/pdf
WHATSAPP_SANDBOX_MODE=false
ALERTS_ENABLED=true
PUBLIC_TRACKING_SALT=
