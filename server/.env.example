NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db
JWT_SECRET=change_me_secure_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
DEMO_SEED=false
CREDENTIALS_ENCRYPTION_KEY=
REQUIRE_WEBHOOK_SIGNATURE=false
JOB_WORKER_ENABLED=true
JOB_WORKER_CONCURRENCY=2
JOB_MAX_ATTEMPTS=5
REALTIME_ENABLED=true
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com
WHATSAPP_SANDBOX_MODE=false
MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_DIR=server/uploads
MEDIA_MAX_SIZE_MB=25
MEDIA_SIGNED_URL_TTL_SECONDS=300
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,audio/mpeg,audio/ogg,video/mp4,application/pdf
ALERTS_ENABLED=true

# Solo para el script manual de rotacion; no conservar juntas en produccion.
OLD_CREDENTIALS_ENCRYPTION_KEY=
NEW_CREDENTIALS_ENCRYPTION_KEY=
